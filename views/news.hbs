{{> menu }}
<body>
    <div class="bg-psc-yellow centered_text">
        <h1>News</h1>
    </div>

    <div class="feature-container-centered gab-4">
        {{#each news}}
            <div class="card centered_text border-0" style="width: 18rem;">
                <img src={{src_img}} class="card-img-top" alt="...">
                <div class="card-body">
                    <h3 class="card-title">{{title}}</h3>
                    <p class="card-text">{{description}}</p>
                    <button type="button" class="btn-psc-blue" data-bs-toggle="modal" data-bs-toggle="modal" data-bs-target="#modal{{@index}}">
                        <p class="card-text">Mehr erfahren>></p>
                    </button>
              </div>
            </div>
            {{> pop_up_news modalId=@index isAdmin=../isAdmin}}
        {{/each}}
    </div>
    <div class="position-sticky text-end pb-3 pr-3">
        {{#if isAdmin}}
        <button type="button" class="btn-psc-blue" data-bs-toggle="modal" data-bs-target="#add">
            <p class="card-text">Artikel hinzufügen</p>
        </button>
        {{/if}}
    </div>
    {{> pop_up_add_edit_article modalId="add"}}
</body>   