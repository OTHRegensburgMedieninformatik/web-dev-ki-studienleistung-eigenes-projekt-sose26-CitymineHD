<div class="modal fade" id="modal{{user_id}}" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal modal-dialog-centered modal-dialog-scrollable modal-lg">
        <div class="modal-content">
            <div class="modal-header d-flex justify-content-center">
                <h5 class="modal-title">Mitglied bearbeiten</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" data-bs-target="#modal{{user_id}}" aria-label="Schließen"></button>
            </div>
            <div class="modal-body text-center d-flex flex-column align-items-center">
                <div class="row d-flex">
                    <div class="col-md-6">
                        <table style="width: 100%; table-layout: fixed;">
                            <tr>
                                <td style="width: 120px; vertical-align: top;"><strong>Vorname:</strong></td>
                                <td>{{firstname}}</td>
                            </tr>
                            <tr>
                                <td><strong>Geburtstag:</strong></td>
                                <td>{{birthday}}</td>
                            </tr>
                            <tr>
                                <td><strong>Postleitzahl:</strong></td>
                                <td>{{postcode}}</td>
                            </tr>
                            <tr>
                                <td><strong>E-Mail:</strong></td>
                                <td>{{mail}}</td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <table style="width: 100%; table-layout: fixed;">
                            <tr>
                                <td style="width: 120px;"><strong>Nachname:</strong></td>
                                <td>{{lastname}}</td>
                            </tr>
                            <tr>
                                <td><strong>Adresse:</strong></td>
                                <td>{{address}}</td>
                            </tr>
                            <tr>
                                <td><strong>Ort:</strong></td>
                                <td>{{city}}</td>
                            </tr>
                            <tr>
                                <td><strong>Telefon:</strong></td>
                                <td>{{phone}}</td>
                            </tr>
                            <tr>
                                <td><strong>Handy:</strong></td>
                                <td>{{handy}}</td>
                            </tr>
                        </table>
                    </div>
                </div>
                <div class="d-flex justify-content-center align-items-center" style="margin: 30px;">
                    <table>
                        <thead>
                            <tr>
                                <th style="padding: 10px; text-align: center;">Mitgliedsstatus</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td style="text-align: center;">{{{applyStatus}}}</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-end">
                <form class="d-flex" style="margin-right: 30px" action="/profile/editMember/{{user_id}}" method="post">
                    <select class="form-select" style="margin-right: 10px;" id="status" name="status">
                        <option value="1">Mitglied</option>
                        <option value="0">Prüfung</option>
                        <option value="2">Abgelehnt</option>
                    </select>
                    <button type="submit" class="btn btn-psc-yellow">Speichern</button>
                </form>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" data-bs-target="#modal{{user_id}}">Schließen</button>
            </div>
        </div>
    </div>
</div>