<div class="modal fade" id="add" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-fullscreen modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header d-flex justify-content-center">
        <h5 class="modal-title">{{title}}</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
      </div>
      <div class="modal-body">
        <div class="bg-psc-yellow centered_text" style="margin: 20px;">
          <h5>Neuen News Artikel hinzufügen</h5>
        </div>

        <div class="row" style="display: flex; justify-content: center;">
          <div class="col-3">
            <input type="text" class="form-control mb-3" id="title" placeholder="Titel">
          </div>
          <div class="col-3">
            <input type="text" class="form-control mb-3" id="description" placeholder="Beschreibung">
          </div>
          <div class="col-3">
            <input type="text" class="form-control mb-3" id="src_img" placeholder="Bild URL">
          </div>
        </div>
        <div id="editorjs" style="overflow-y: auto; background-color: #f8f9fa; border: 1px solid #ced4da;"></div>

        <div class="mt-3" style="display: flex; justify-content: center;">
          <button class="btn btn-psc-yellow" onclick="save()">Artikel speichern</button>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-psc-yellow" data-bs-dismiss="modal">Schließen</button>
      </div>
    </div> 
  </div>
</div>

<script>
  class Image {
    static get toolbox() {
      return {
        title: 'Image',
        icon: '<svg width="17" height="15" viewBox="0 0 336 276" xmlns="http://www.w3.org/2000/svg"><path d="M291 150V79c0-19-15-34-34-34H79c-19 0-34 15-34 34v42l67-44 81 72 56-29 42 30zm0 52l-43-30-56 30-81-67-66 39v23c0 19 15 34 34 34h178c17 0 31-13 34-29zM79 0h178c44 0 79 35 79 79v118c0 44-35 79-79 79H79c-44 0-79-35-79-79V79C0 35 35 0 79 0z"/></svg>'
      };
    }
    constructor({data}) {
      this.data = data;
    }

    render(){
      return document.createElement('input');
    }

    save(blockContent){
      return {
        url: blockContent.value
      }
    }
  }

  const editor = new EditorJS({
    holder: 'editorjs',
    placeholder: 'Hier kannst du deinen Artikel verfassen...',
    
    tools: {
      color: {
        class: window.ColorPicker.default,
      },
      paragraph: {
        class: Paragraph,
        inlineToolbar: ['bold', 'italic', 'color'],
        config: {
          placeholder: 'Text eingeben...',
        }
      },
      header: {
        class: Header,
        inlineToolbar: ['bold', 'italic', 'color'],
        config: {
          placeholder: 'Überschrift eingeben...',
          levels: [2, 3, 4],
          defaultLevel: 2,
        }
      },
      checklist: {
        class: Checklist,
        inlineToolbar: ['bold', 'italic', 'color'],
        config: {
          placeholder: 'Aufgabe eingeben...'
        }
      },
      list: {
        class: List,
        inlineToolbar: ['bold', 'italic', 'color'],
        config: {
          placeholder: 'Listelement eingeben...',
          defaultStyle: 'unordered'
        }
      },
    },
  });
  
  function save() {
    editor.save().then((outputData) => {
      const data = {
        title: document.getElementById('title').value,
        description: document.getElementById('description').value,
        src_img: document.getElementById('src_img').value,
        content: outputData
      };

      const response = fetch('/news/addNews', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
      });
    }).catch((e) => {
      console.log('Saving failed: ', e)
    });
  }
</script>