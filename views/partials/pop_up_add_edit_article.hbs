<div class="modal fade" id="add{{id}}" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-fullscreen modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header d-flex justify-content-center">
        <h5 class="modal-title">{{title}}</h5>
        <button type="button" class="btn-close" onclick="destroyEditor()" data-bs-dismiss="modal" aria-label="Schließen"></button>
      </div>
      <div class="modal-body">
        <div class="bg-psc-yellow centered_text" style="margin: 20px;">
          <h5>Neuen News Artikel hinzufügen</h5>
        </div>

        <div class="row" style="display: flex; justify-content: center;">
          <div class="col-3">
            <input type="text" class="form-control mb-3" id="title-{{id}}" placeholder="Titel" value="{{title}}">
          </div>
          <div class="col-3">
            <input type="text" class="form-control mb-3" id="description-{{id}}" placeholder="Beschreibung" value="{{description}}">
          </div>
          <div class="col-3">
            <input type="file" class="form-control mb-3" id="src_img-{{id}}" placeholder="Bild URL" value="{{src_img}}">
          </div>
        </div>

        <div id="id-bridge" style="display: none;">{{{id}}}</div>
        <div id="content-bridge" style="display: none;">{{{content}}}</div>

        <div id="editorjs-{{id}}" style="overflow-y: auto; background-color: #f8f9fa; border: 1px solid #ced4da;"></div>

        <div class="mt-3" style="display: flex; justify-content: center;">
          <button class="btn btn-psc-yellow" onclick="save('{{id}}')">Artikel speichern</button>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-psc-yellow" onclick="destroyEditor()" data-bs-dismiss="modal">Schließen</button>
      </div>
    </div> 
  </div>
</div>